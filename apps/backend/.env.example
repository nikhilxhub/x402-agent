# ── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Restrict CORS to your frontend domain in production
CORS_ORIGIN=*

# ── Solana ───────────────────────────────────────────────────────────────────
SOLANA_RPC=https://api.devnet.solana.com
SOLANA_NETWORK=devnet

# Your platform's Solana wallet address (payment recipient)
PLATFORM_WALLET=YourPlatformWalletAddressHere

# Required payment per request (0.01 SOL = 10,000,000 lamports)
X402_PAYMENT_AMOUNT_LAMPORTS=10000000

# ── AI Providers (Vercel AI SDK) ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx
GOOGLE_GENERATIVE_AI_API_KEY=AIzaxxxxx
TOGETHER_API_KEY=xxxxx

# Load balancing strategy: "cheapest" | "round-robin"
LOAD_BALANCING_STRATEGY=cheapest

# ── MagicBlock Private Payments ──────────────────────────────────────────────
MAGICBLOCK_API_KEY=your_magicblock_api_key
MAGICBLOCK_API_BASE=https://api.magicblock.gg/v1
MAGICBLOCK_NETWORK=mainnet
