# ── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Restrict CORS to your frontend domain in production
CORS_ORIGIN=*

# ── Solana ───────────────────────────────────────────────────────────────────
SOLANA_RPC=https://api.devnet.solana.com
SOLANA_NETWORK=devnet

# Your platform's Solana wallet address (payment recipient)
PLATFORM_WALLET=YourPlatformWalletAddressHere

# Required payment per request (0.01 SOL = 10,000,000 lamports)
X402_PAYMENT_AMOUNT_LAMPORTS=10000000

# ── AI Providers (Vercel AI SDK) ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx
GOOGLE_GENERATIVE_AI_API_KEY=AIzaxxxxx
TOGETHER_API_KEY=xxxxx

# Load balancing strategy: "cheapest" | "round-robin"
LOAD_BALANCING_STRATEGY=cheapest

# ── MagicBlock Private Payments ──────────────────────────────────────────────
# MagicBlock requires NO API key — auth is via wallet signatures on-chain.
# API reference: https://payments.magicblock.app/reference

# Base58-encoded private key of your platform wallet (used to sign settlement txs).
# Leave blank to use simulated settlement mode (logs splits, no on-chain transfers).
PLATFORM_WALLET_PRIVATE_KEY=

# Cluster for MagicBlock transfers: "mainnet" | "devnet"
MAGICBLOCK_NETWORK=devnet

# Optional: override the USDC mint (defaults to the right one per cluster automatically)
# Mainnet default: EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
# Devnet default:  4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
# MAGICBLOCK_USDC_MINT=

# Optional: override MagicBlock's ephemeral (TEE) RPC endpoint
# Defaults: mainnet → https://mainnet-tee.magicblock.app
#           devnet  → https://devnet-tee.magicblock.app
# MAGICBLOCK_EPHEMERAL_RPC=https://devnet-tee.magicblock.app
